{
	"compilerOptions": {
		"allowJs": true,
		"baseUrl": ".",
		"checkJs": true,
		"forceConsistentCasingInFileNames": true,
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"paths": {
			"svelte-dnd": ["../lib/src/lib/index.ts"]
		},
		"resolveJsonModule": true,
		"rewriteRelativeImportExtensions": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"types": ["svelte"]
	},
	"include": ["src/**/*.ts", "src/**/*.svelte", "vite.config.ts"]
}
